# Packages installed by modules/80-dev-packages.sh.
#
# One apt package name per line. Blank lines and lines starting with # are
# ignored. This is the "add stuff here as you go" extension point: add a
# package name, commit, and re-run install.sh to pick it up.
#
# Kept deliberately minimal rather than pre-loaded with guessed language
# runtimes and toolchains — it's meant to grow as actual needs appear. None
# of these are preinstalled on a stock Pop!_OS desktop.

git
curl
build-essential
tmux
jq
unzip
